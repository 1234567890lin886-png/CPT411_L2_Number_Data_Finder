    def get_text(self) -> str:
        return self.input_text.get("1.0", "end-1c")

    def analyze_now(self):
        self.stop_visual(silent=True)
        text = self.get_text()
        matches = find_l2_patterns(text)
        self.current_text = text
        self.final_matches = matches
        self.update_summary(matches, "qDone", "Instant analysis", "Finished without animation.")
        self.update_table(matches)
        self.update_highlight(text, matches, None)
        self.set_output(format_result(text, matches))
        self.clear_log()
        self.add_log("Instant analysis completed. Click Visualize Step by Step to show the DFA process.")
        self.draw_dfa("qDone")

    def start_visual(self):
        self.stop_visual(silent=True)
        self.current_text = self.get_text()
        self.steps, self.final_matches = build_dfa_trace(self.current_text)
        self.step_index = 0
        self.live_matches = []
        self.running = True
        self.paused = False
        self.pause_btn.configure(text="Pause", state="normal")
        self.stop_btn.configure(state="normal")
        self.update_table([])
        self.update_highlight(self.current_text, [], None)
        self.set_output(format_result(self.current_text, self.final_matches))
        self.clear_log()
        self.add_log("DFA visualization started.")
        self.root.after(0, self.next_step)

    def next_step(self):
        if not self.running or self.paused:
            return

        if self.step_index >= len(self.steps):
            self.finish_visual()
            return

        s = self.steps[self.step_index]
        self.step_index += 1

        if s.match and not any(m.start == s.match.start and m.end == s.match.end for m in self.live_matches):
            self.live_matches.append(s.match)

        self.update_summary(self.live_matches, s.state, s.action, s.detail)
        self.update_table(self.live_matches)
        self.update_highlight(self.current_text, self.live_matches, (s.start, s.end))
        self.draw_dfa(s.state)
        self.add_log(
            f"Step {self.step_index:03d} | pos={s.pos:03d} | char={safe_char(self.current_text, s.pos)!r} "
            f"| {s.state} | {s.action} | {s.detail}"
        )
        self.after_id = self.root.after(int(self.delay.get()), self.next_step)

    def finish_visual(self):
        self.running = False
        self.paused = False
        self.pause_btn.configure(text="Pause", state="disabled")
        self.stop_btn.configure(state="disabled")
        self.update_summary(self.final_matches, "qDone", "Finished", "The DFA has scanned the whole input.")
        self.update_table(self.final_matches)
        self.update_highlight(self.current_text, self.final_matches, None)
        self.draw_dfa("qDone")
        self.add_log("DFA visualization finished.")

    def pause_resume(self):
        if not self.running:
            return
        self.paused = not self.paused
        if self.paused:
            if self.after_id:
                self.root.after_cancel(self.after_id)
                self.after_id = None
            self.pause_btn.configure(text="Resume")
            self.add_log("Paused.")
        else:
            self.pause_btn.configure(text="Pause")
            self.add_log("Resumed.")
            self.next_step()

    def stop_visual(self, silent=False):
        if self.after_id:
            try:
                self.root.after_cancel(self.after_id)
            except tk.TclError:
                pass
            self.after_id = None

        was_running = self.running
        self.running = False
        self.paused = False

        if hasattr(self, "pause_btn"):
            self.pause_btn.configure(text="Pause", state="disabled")
            self.stop_btn.configure(state="disabled")

        if was_running and not silent:
            self.add_log("Stopped.")

    def update_summary(self, matches, state, action, detail):
        self.status_var.set("Status: " + ("ACCEPT" if matches else "REJECT"))
        self.count_var.set(f"Occurrences so far: {len(matches)}")
        self.state_var.set(f"State: {state}")
        self.action_var.set(f"Action: {action}")
        self.detail_var.set(f"Detail: {detail}")

    def update_table(self, matches):
        for row in self.table.get_children():
            self.table.delete(row)
        for i, m in enumerate(matches, 1):
            self.table.insert("", "end", values=(f"{i:02d}", m.token, m.kind, f"{m.start}-{m.end - 1}"))

    def update_highlight(self, text, matches, current):
        self.highlight.configure(state="normal")
        self.highlight.delete("1.0", "end")
        self.highlight.insert("1.0", text)

        for m in matches:
            self.highlight.tag_add("accepted", f"1.0+{m.start}c", f"1.0+{m.end}c")

        if current:
            a, b = current
            if a == b and a < len(text):
                b = a + 1
            if a < len(text):
                self.highlight.tag_add("current", f"1.0+{a}c", f"1.0+{min(b, len(text))}c")
                self.highlight.see(f"1.0+{a}c")

        self.highlight.configure(state="disabled")

    def set_output(self, content):
        self.output.configure(state="normal")
        self.output.delete("1.0", "end")
        self.output.insert("1.0", content)
        self.output.configure(state="disabled")

    def clear_log(self):
        self.log.configure(state="normal")
        self.log.delete("1.0", "end")
        self.log.configure(state="disabled")

    def add_log(self, line):
        self.log.configure(state="normal")
        self.log.insert("end", line + "\n")
        self.log.see("end")
        self.log.configure(state="disabled")

    def _start_canvas_pan(self, event):
        self.canvas.scan_mark(event.x, event.y)

    def _drag_canvas_pan(self, event):
        self.canvas.scan_dragto(event.x, event.y, gain=1)

    def draw_dfa(self, active):
        c = self.canvas
        c.delete("all")

        nodes = {
            "qScan": (90, 220),
            "qDigit": (320, 90),
            "qInteger": (610, 90),
            "qPercent": (970, 40),
            "qOrdinal": (970, 150),
            "qYear": (970, 260),
            "qNoSpaceUnit": (970, 370),
            "qSpaceBranch": (1280, 150),
            "qQuantity": (1600, 70),
            "qDateDMY": (1600, 220),
            "qMonthStart": (320, 360),
            "qDateMDY": (970, 520),
            "qTrap": (1280, 370),
            "qReject": (1600, 430),
            "qAccept": (1910, 220),
            "qDone": (2120, 220),
            "qSkip": (320, 220),
        }

        radius = 34

        def right_point(x, y):
            return x + radius, y

        def left_point(x, y):
            return x - radius, y

        def arrow(a, b, label="", y_shift=0):
            x1, y1 = nodes[a]
            x2, y2 = nodes[b]
            sx, sy = right_point(x1, y1)
            ex, ey = left_point(x2, y2)
            c.create_line(sx, sy, ex, ey, arrow=tk.LAST, fill="#777", width=2)
            if label:
                c.create_text((sx + ex) / 2, ((sy + ey) / 2) + y_shift, text=label, font=("Segoe UI", 8), fill="#555")

        def back_arrow(a, b, label="", y_shift=0):
            x1, y1 = nodes[a]
            x2, y2 = nodes[b]
            c.create_line(
                x1, y1 + radius, x1, y1 + 46,
                x2, y2 + 46, x2, y2 + radius,
                smooth=True, arrow=tk.LAST, fill="#999", width=2
            )
            if label:
                c.create_text((x1 + x2) / 2, max(y1, y2) + 56 + y_shift, text=label, font=("Segoe UI", 8), fill="#666")

        def loop_arrow(state, label):
            x, y = nodes[state]
            c.create_arc(x - 25, y - 55, x + 25, y - 5, start=40, extent=280, style=tk.ARC, outline="#777", width=2)
            c.create_text(x, y - 62, text=label, font=("Segoe UI", 8), fill="#555")

        edges = [
            ("qScan", "qDigit", "digit", -10),
            ("qScan", "qMonthStart", "letter", 10),
            ("qScan", "qSkip", "other", 18),
            ("qDigit", "qInteger", "consume digits", -12),
            ("qInteger", "qPercent", "% / .digits%", -12),
            ("qInteger", "qOrdinal", "st|nd|rd|th", 0),
            ("qInteger", "qYear", "4 digits + boundary", 0),
            ("qInteger", "qNoSpaceUnit", "kg|km", 8),
            ("qInteger", "qSpaceBranch", "space", -10),
            ("qSpaceBranch", "qQuantity", "unit", -12),
            ("qSpaceBranch", "qDateDMY", "Month + YYYY", 8),
            ("qMonthStart", "qDateMDY", "Month Day Year", 12),
            ("qInteger", "qTrap", "invalid long day", 22),
            ("qInteger", "qReject", "no valid branch", 32),
            ("qMonthStart", "qReject", "not a date", 30),
            ("qPercent", "qAccept", "accept", -12),
            ("qOrdinal", "qAccept", "accept", -2),
            ("qYear", "qAccept", "accept", 4),
            ("qNoSpaceUnit", "qAccept", "accept", 12),
            ("qQuantity", "qAccept", "accept", -8),
            ("qDateDMY", "qAccept", "accept", 4),
            ("qDateMDY", "qAccept", "accept", 18),
            ("qSkip", "qDone", "end", 14),
            ("qAccept", "qDone", "end", -10),
        ]

        for a, b, label, y_shift in edges:
            arrow(a, b, label, y_shift)

        back_arrow("qAccept", "qScan", "continue scanning")
        back_arrow("qReject", "qScan", "next position", 8)
        back_arrow("qTrap", "qScan", "skip invalid token", 16)

        loop_arrow("qScan", "scan loop")

        for state, (x, y) in nodes.items():
            if state == active:
                fill, outline, width = "#ffd37a", "#c77700", 3
            elif state == "qAccept":
                fill, outline, width = "#d7f7d7", "#4b9b4b", 2
            elif state in ("qReject", "qTrap"):
                fill, outline, width = "#ffd6d6", "#b64b4b", 2
            elif state == "qDone":
                fill, outline, width = "#ececec", "#666666", 2
            else:
                fill, outline, width = "#eef5ff", "#5f7ea8", 1

            c.create_oval(
                x - radius, y - radius, x + radius, y + radius,
                fill=fill, outline=outline, width=width
            )

            if state == "qAccept":
                c.create_oval(
                    x - radius + 6, y - radius + 6, x + radius - 6, y + radius - 6,
                    outline=outline, width=1
                )

            c.create_text(
                x, y,
                text=STATE_LABELS.get(state, state),
                font=("Segoe UI", 8),
                justify="center"
            )

        bbox = c.bbox("all")
        if bbox:
            pad = 60
            c.configure(scrollregion=(bbox[0] - pad, bbox[1] - pad, bbox[2] + pad, bbox[3] + pad))
    def load_demo(self):
        self.stop_visual(silent=True)
        self.input_text.delete("1.0", "end")
        self.input_text.insert("1.0", DEMO_TEXT)
        self.analyze_now()

    def clear_all(self):
        self.stop_visual(silent=True)
        self.input_text.delete("1.0", "end")
        self.analyze_now()

    def load_file(self):
        self.stop_visual(silent=True)
        path = filedialog.askopenfilename(
            title="Choose a text file",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")]
        )
        if not path:
            return

        try:
            with open(path, "r", encoding="utf-8") as f:
                content = f.read()
        except UnicodeDecodeError:
            with open(path, "r", encoding="gbk", errors="replace") as f:
                content = f.read()
        except OSError as e:
            messagebox.showerror("Load failed", str(e))
            return

        self.input_text.delete("1.0", "end")
        self.input_text.insert("1.0", content)
        self.analyze_now()

    def save_result(self):
        content = self.output.get("1.0", "end-1c")
        log = self.log.get("1.0", "end-1c")

        if log.strip():
            content += "\n\n" + "=" * 70 + "\nDFA PROCESS LOG\n" + "=" * 70 + "\n" + log

        path = filedialog.asksaveasfilename(
            title="Save result",
            defaultextension=".txt",
            filetypes=[("Text files", "*.txt"), ("All files", "*.*")]
        )
        if not path:
            return

        try:
            with open(path, "w", encoding="utf-8") as f:
                f.write(content)
        except OSError as e:
            messagebox.showerror("Save failed", str(e))
            return

        messagebox.showinfo("Saved", "Result saved successfully.")


