class L2DFAVisualizerApp:
    def __init__(self, root: tk.Tk):
        self.root = root
        self.root.title("L2 Number Data Finder - DFA Visualizer")
        self.root.geometry("1220x800")
        self.root.minsize(1050, 680)

        self.steps: List[TraceStep] = []
        self.step_index = 0
        self.after_id = None
        self.running = False
        self.paused = False
        self.live_matches: List[Match] = []
        self.final_matches: List[Match] = []
        self.current_text = ""

        self._build_style()
        self._build_ui()
        self.input_text.insert("1.0", DEMO_TEXT)
        self.analyze_now()

    def _build_style(self):
