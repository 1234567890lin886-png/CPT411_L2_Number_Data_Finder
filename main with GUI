@dataclass
class TraceStep:
    pos: int
    state: str
    action: str
    detail: str
    start: int
    end: int
    match: Optional[Match] = None

def safe_char(text: str, pos: int) -> str:
    if pos >= len(text):
        return "<END>"
    ch = text[pos]
    if ch == "\n":
        return "\\n"
    if ch == "\t":
        return "\\t"
    if ch.isspace():
        return "<space>"
    return ch

def step(text: str, pos: int, state: str, action: str, detail: str,
         start: Optional[int] = None, end: Optional[int] = None,
         match: Optional[Match] = None) -> TraceStep:
    n = len(text)
    pos = max(0, min(pos, n))
    if start is None:
        start = pos
    if end is None:
        end = min(pos + 1, n)
    start = max(0, min(start, n))
    end = max(start, min(end, n))
    return TraceStep(pos, state, action, detail, start, end, match)

def build_dfa_trace(text: str) -> Tuple[List[TraceStep], List[Match]]:
    trace: List[TraceStep] = []
    matches: List[Match] = []
    i = 0
    n = len(text)

    while i < n:
        ch = text[i]
        trace.append(step(text, i, "qScan", "Read character", f"Read position {i}: {safe_char(text, i)!r}."))

        if is_digit(ch):
            trace.append(step(
                text, i, "qDigit", "Digit branch",
                "The character is a digit, so the DFA enters the numeric branch."
            ))

            integer = consume_integer_body(text, i)
            if integer is None:
                trace.append(step(
                    text, i, "qReject", "REJECT",
                    "The numeric branch could not consume a valid integer body."
                ))
                i += 1
                continue

            end_i, digits, has_comma = integer
            trace.append(step(
                text, i, "qInteger", "Consume integer body",
                f"Integer candidate: {text[i:end_i]!r}, digits={digits}, contains_comma={has_comma}.",
                i, end_i
            ))

            if end_i < n and text[end_i] == "%":
                end = end_i + 1
                trace.append(step(
                    text, end_i, "qPercent", "Check percentage",
                    "Found '%' immediately after the integer body.",
                    i, end
                ))
                if has_right_boundary(text, end):
                    found = Match(text[i:end], "percentage", i, end)
                    trace.append(step(
                        text, i, "qAccept", "ACCEPT",
                        f"Accepted {found.token!r} as {found.kind}.",
                        found.start, found.end, found
                    ))
                    matches.append(found)
                    i = found.end
                    continue
                trace.append(step(
                    text, i, "qReject", "REJECT",
                    "Percentage candidate failed right-boundary checking.",
                    i, end
                ))
                i += 1
                continue

            dec = consume_decimal_fraction(text, end_i)
            if dec is not None:
                dec_end, frac_digits = dec
                trace.append(step(
                    text, end_i, "qPercent", "Check decimal percentage",
                    f"Found decimal fraction with {frac_digits} digit(s).",
                    i, dec_end
                ))
                if dec_end < n and text[dec_end] == "%":
                    end = dec_end + 1
                    if has_right_boundary(text, end):
                        found = Match(text[i:end], "percentage", i, end)
                        trace.append(step(
                            text, i, "qAccept", "ACCEPT",
                            f"Accepted {found.token!r} as {found.kind}.",
                            found.start, found.end, found
                        ))
                        matches.append(found)
                        i = found.end
                        continue
                trace.append(step(
                    text, i, "qReject", "REJECT",
                    "Decimal number did not complete a valid percentage token.",
                    i, dec_end
                ))
                i += 1
                continue

            if not has_comma:
                suffixes = [("st", "ordinal"), ("nd", "ordinal"), ("rd", "ordinal"), ("th", "ordinal")]
                accepted = False
                for suffix, kind in suffixes:
                    end = match_word(text, end_i, suffix)
                    if end is not None:
                        trace.append(step(
                            text, end_i, "qOrdinal", "Check ordinal suffix",
                            f"Found ordinal suffix {suffix!r}.",
                            i, end
                        ))
                        if has_right_boundary(text, end):
                            found = Match(text[i:end], kind, i, end)
                            trace.append(step(
                                text, i, "qAccept", "ACCEPT",
                                f"Accepted {found.token!r} as {found.kind}.",
                                found.start, found.end, found
                            ))
                            matches.append(found)
                            i = found.end
                            accepted = True
                            break
                if accepted:
                    continue

            accepted = False
            for unit, kind in UNITS_NO_SPACE:
                end = match_word(text, end_i, unit)
                if end is not None:
                    trace.append(step(
                        text, end_i, "qNoSpaceUnit", "Check no-space unit",
                        f"Found no-space unit {unit!r}.",
                        i, end
                    ))
                    if has_right_boundary(text, end):
                        found = Match(text[i:end], kind, i, end)
                        trace.append(step(
                            text, i, "qAccept", "ACCEPT",
                            f"Accepted {found.token!r} as {found.kind}.",
                            found.start, found.end, found
                        ))
                        matches.append(found)
                        i = found.end
                        accepted = True
                        break
            if accepted:
                continue

            if not has_comma and digits == 4 and has_right_boundary(text, end_i):
                trace.append(step(
                    text, end_i, "qYear", "Check four-digit year",
                    "The token has exactly four digits and passes boundary checking.",
                    i, end_i
                ))
                found = Match(text[i:end_i], "year", i, end_i)
                trace.append(step(
                    text, i, "qAccept", "ACCEPT",
                    f"Accepted {found.token!r} as {found.kind}.",
                    found.start, found.end, found
                ))
                matches.append(found)
                i = found.end
                continue

            if end_i < n and text[end_i].isspace():
                after_space = skip_spaces(text, end_i)
                trace.append(step(
                    text, end_i, "qSpaceBranch", "Space branch",
                    "After the number, whitespace is found. The DFA checks quantity and day-month-year date branches.",
                    i, after_space
                ))

                if not has_comma and digits in (1, 2):
                    month_match = match_any_word(text, after_space, MONTHS)
                    if month_match is not None:
                        month_word, m_end = month_match
                        if m_end < n and text[m_end].isspace():
                            after_month_space = skip_spaces(text, m_end)
                            year_end = consume_four_digit_year(text, after_month_space)
                            trace.append(step(
                                text, after_space, "qDateDMY", "Check day-month-year date",
                                f"Found month {month_word!r} after a 1-2 digit day candidate.",
                                i, after_month_space
                            ))
                            if year_end is not None:
                                found = Match(text[i:year_end], "date", i, year_end)
                                trace.append(step(
                                    text, i, "qAccept", "ACCEPT",
                                    f"Accepted {found.token!r} as {found.kind}.",
                                    found.start, found.end, found
                                ))
                                matches.append(found)
                                i = found.end
                                continue

                unit_words = [u for u, _ in UNITS_AFTER_SPACE]
                unit_match = match_any_word(text, after_space, unit_words)
                if unit_match is not None:
                    unit_word, unit_end = unit_match
                    trace.append(step(
                        text, after_space, "qQuantity", "Check quantity",
                        f"Found quantity unit {unit_word!r}.",
                        i, unit_end
                    ))
                    if has_right_boundary(text, unit_end):
                        found = Match(text[i:unit_end], "quantity", i, unit_end)
                        trace.append(step(
                            text, i, "qAccept", "ACCEPT",
                            f"Accepted {found.token!r} as {found.kind}.",
                            found.start, found.end, found
                        ))
                        matches.append(found)
                        i = found.end
                        continue

            invalid_end = invalid_long_day_month_year_end(text, i)
            if invalid_end is not None:
                trace.append(step(
                    text, i, "qTrap", "TRAP invalid date-like token",
                    "Rejected a long day-month-year shape so the inner year is not accepted separately.",
                    i, invalid_end
                ))
                i = invalid_end
                continue

            trace.append(step(
                text, i, "qReject", "REJECT",
                "No numeric-start pattern is accepted at this position."
            ))
            i += 1
            continue

        if is_letter(ch):
            trace.append(step(
                text, i, "qMonthStart", "Letter branch",
                "The character is a letter, so the DFA checks whether it starts a month-day-year date."
            ))
            found = try_month_day_year(text, i)
            if found is not None:
                trace.append(step(
                    text, i, "qDateMDY", "Check month-day-year date",
                    f"Month-start date candidate found: {found.token!r}.",
                    found.start, found.end
                ))
                trace.append(step(
                    text, i, "qAccept", "ACCEPT",
                    f"Accepted {found.token!r} as {found.kind}.",
                    found.start, found.end, found
                ))
                matches.append(found)
                i = found.end
                continue

            trace.append(step(
                text, i, "qReject", "REJECT",
                "This letter does not start a valid month-day-year date."
            ))
            i += 1
            continue

        trace.append(step(
            text, i, "qSkip", "Skip",
            "This character is not a possible token start."
        ))
        i += 1

    trace.append(step(
        text, n, "qDone", "Finished",
        f"Scanning finished. Total accepted patterns: {len(matches)}.",
        n, n
    ))
    return trace, matches

def format_result(text: str, matches: List[Match]) -> str:
    lines = []
    lines.append("=" * 70)
    lines.append("Pattern (input string): L2 Number Data Finder")
    lines.append("Recognized categories: ordinal, percentage, quantity, year, date")
    lines.append("=" * 70)
    lines.append("Text used for demo:")
    lines.append(text)
    lines.append("=" * 70)
    lines.append("Status: ACCEPT" if matches else "Status: REJECT")
    lines.append(f"Occurrences of patterns: {len(matches)}")
    if matches:
        lines.append("\nAccepted patterns:")
        for index, m in enumerate(matches, 1):
            lines.append(f"{index:02d}. {m.token!r} | category={m.kind} | position={m.start}-{m.end - 1}")
        lines.append("\nVisualization using boldface:")
        lines.append(highlight_text(text, matches))
    return "\n".join(lines)

