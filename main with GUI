            pass
        style.configure("Title.TLabel", font=("Segoe UI", 18, "bold"))
        style.configure("Action.TButton", font=("Segoe UI", 10), padding=6)
        style.configure("Status.TLabel", font=("Segoe UI", 12, "bold"))
        style.configure("Treeview", rowheight=25)
        style.configure("Treeview.Heading", font=("Segoe UI", 10, "bold"))

    def _build_ui(self):
        main = ttk.Frame(self.root, padding=12)
        main.pack(fill="both", expand=True)

        ttk.Label(main, text="L2 Number Data Finder - DFA Process Visualizer", style="Title.TLabel").pack(anchor="w")


        bar = ttk.Frame(main)
        bar.pack(fill="x", pady=(0, 8))

        ttk.Button(bar, text="Analyze Now", style="Action.TButton", command=self.analyze_now).pack(side="left", padx=(0, 6))
